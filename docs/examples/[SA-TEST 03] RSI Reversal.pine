//@version=6
strategy(
     title                            = "[SA-TEST 03]",
     overlay                          = false,
     initial_capital                  = 10000,
     default_qty_type                 = strategy.percent_of_equity,
     default_qty_value                = 100,
     pyramiding                       = 0,
     commission_type                  = strategy.commission.percent,
     commission_value                 = 0.01,
     slippage                         = 0,
     margin_long                      = 0,
     margin_short                     = 0,
     calc_on_order_fills              = true,
     calc_on_every_tick               = true,
     process_orders_on_close          = true,
     fill_orders_on_standard_ohlc     = true)

// Classic RSI reversal:
//   long  when RSI crosses BACK ABOVE oversold (i.e., recovering from a dip)
//   exit  when RSI crosses BACK BELOW overbought (i.e., reversing from a top)
length      = 14
oversold    = 30
overbought  = 70

rsi = ta.rsi(close, length)

longCondition  = ta.crossover(rsi, oversold)
exitCondition  = ta.crossunder(rsi, overbought)

if longCondition
    strategy.entry("Long", strategy.long)

if exitCondition
    strategy.close("Long")

// Optional: plot the RSI with threshold lines
plot(rsi, "RSI", color.aqua)
hline(oversold,   "Oversold",   color.green)
hline(overbought, "Overbought", color.red)
