//@version=6
strategy(
     title                            = "[SA-TEST 02]",
     overlay                          = true,
     initial_capital                  = 10000,
     default_qty_type                 = strategy.percent_of_equity,
     default_qty_value                = 100,
     pyramiding                       = 0,
     commission_type                  = strategy.commission.percent,
     commission_value                 = 0.01,
     slippage                         = 0,
     margin_long                      = 0,
     margin_short                     = 0,
     calc_on_order_fills              = true,
     calc_on_every_tick               = true,
     process_orders_on_close          = true,
     fill_orders_on_standard_ohlc     = true)

// Same structure as SA-TEST 01 SMA crossover, but with EMAs.
// EMAs react faster than SMAs of the same length -- expect more trades.
fastMA = ta.ema(close, 14)
slowMA = ta.ema(close, 28)

longCondition  = ta.crossover(fastMA, slowMA)
exitCondition  = ta.crossunder(fastMA, slowMA)

if longCondition
    strategy.entry("Long", strategy.long)

if exitCondition
    strategy.close("Long")

// Optional: plot the MAs so you can eyeball the signals
plot(fastMA, "Fast EMA", color.aqua)
plot(slowMA, "Slow EMA", color.orange)
